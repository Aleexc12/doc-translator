# --- OpenAI (cloud) ---
# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom endpoint (OpenAI-compatible: Azure, Ollama, LM Studio, vLLM, …)
# Cloud default when unset: https://api.openai.com/v1
# OPENAI_API_BASE=https://api.openai.com/v1

# Optional: Model selection (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# --- Ollama ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1 # default http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2 # default llama3.2

# Optional. Leave empty if not needed.
# OLLAMA_API_KEY=ollama